flowchart TB
    User([User]) --> HTML["index.html\nApp shell"]

    subgraph Frontend["Frontend (ES Modules)"]
        HTML --> app["app.js\nEntry point"]
        app --> state["state.js\nGame state + auth helpers"]
        app --> data["data.js\nRanks, badges, categories, sample quests"]
        app --> render["render.js\nQuest grid, detail modal, hunter card"]
        app --> events["events.js\nFilters, quest actions, Poogie, SOS"]
        app --> utils["utils.js\nHelpers"]
    end

    subgraph Convex["Convex Backend"]
        state <-->|"mutations / queries"| auth["auth.ts\nLogin / register"]
        state <-->|"mutations / queries"| quests["quests.ts\nQuest CRUD + lifecycle"]
        auth & quests --> DB[("Database\nusers / quests / hunters")]
    end

    state <-->|"offline fallback"| Storage[("localStorage")]
